<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {% for page in pages %}
  <url>
    <loc>{{ url | e }}{{ page.url | e }}</loc>
    {% if page.lastmod %}<lastmod>{{ page.lastmod | e }}</lastmod>{% endif %}
    <changefreq>{{ page.changefreq | default('monthly') | e }}</changefreq>
    <priority>{{ page.priority | default('0.5') | e }}</priority>
  </url>
  {% endfor %}
</urlset>
